{
  "name": "nanocode",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "description": "NanoCode - Electron Desktop App",
  "author": "NanoCode <nanocode@example.com>",
  "homepage": "https://github.com/nanocode/nanocode",
  "scripts": {
    "dev": "concurrently \"vite --port=5173\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build && electron-builder",
    "build:linux": "vite build && electron-builder --linux",
    "build:win": "vite build && electron-builder --win",
    "build:win:portable": "vite build && electron-builder --win portable",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron": "^41.3.0",
    "express": "^4.21.2",
    "glob": "^10.3.10",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/glob": "^8.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.nanocode.app",
    "productName": "NanoCode",
    "directories": {
      "output": "dist-electron"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
